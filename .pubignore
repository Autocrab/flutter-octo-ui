# .pubignore — files kept in the repo but stripped from the published
# package. When present, this file *replaces* .gitignore for pub-publish
# purposes (not layered on top), so we mirror the .gitignore patterns
# and add the dev-only assets pub doesn't need.

# --- mirror .gitignore --------------------------------------------------

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.buildlog/
.history
.svn/
migrate_working_dir/

# IntelliJ / IDE
*.iml
*.ipr
*.iws
.idea/
.vscode/

# Flutter / Dart / Pub
pubspec.lock
**/doc/api/
.dart_tool/
.flutter-plugins-dependencies
build/
coverage/
docs/
CLAUDE.md

# golden_matrix CI reports + failure artifacts.
test/goldens/**/*_report.xml
test/goldens/**/*_report.html
test/goldens/**/*_report.md
test/goldens/**/*_report.json
test/goldens/**/failures/

# --- pub-only exclusions ------------------------------------------------

# Tests + golden baselines — about a megabyte of PNGs that consumers
# never need.
test/

# CI plumbing.
.github/

# Tooling configs — consumers ship their own analyzer / project files.
analysis_options.yaml
.metadata

# Example platform scaffolding. Keep `example/lib/`, `example/pubspec.yaml`,
# and `example/README.md` so pub.dev renders the demo source, but skip
# the per-platform runner folders — they're multi-megabyte and
# regenerated by `flutter create` anyway.
example/macos/
example/linux/
example/windows/
example/ios/
example/android/
example/web/
example/test/
example/build/
example/.dart_tool/
example/pubspec.lock
example/analysis_options.yaml
example/*.iml
